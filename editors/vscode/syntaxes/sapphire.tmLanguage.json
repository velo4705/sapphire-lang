{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sapphire",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sapphire",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sapphire",
          "match": "\\b(if|else|elif|for|while|break|continue|return|match|case|default)\\b"
        },
        {
          "name": "keyword.other.sapphire",
          "match": "\\b(fn|class|trait|impl|import|from|as|let|var|const)\\b"
        },
        {
          "name": "keyword.control.async.sapphire",
          "match": "\\b(async|await|chan|go|select)\\b"
        },
        {
          "name": "keyword.control.exception.sapphire",
          "match": "\\b(try|catch|finally|throw)\\b"
        },
        {
          "name": "storage.type.sapphire",
          "match": "\\b(int|float|double|str|bool|void)\\b"
        },
        {
          "name": "constant.language.sapphire",
          "match": "\\b(true|false|none|None|Some|Ok|Err|Self)\\b"
        },
        {
          "name": "storage.modifier.sapphire",
          "match": "\\b(pub|priv|static|mut|owned)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sapphire",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sapphire",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sapphire",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sapphire",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sapphire",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.sapphire",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.sapphire",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.decorator.sapphire",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sapphire",
          "match": "(\\+|\\-|\\*|\\/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|=|\\+=|\\-=|\\*=|\\/=|%=|->|<-|\\?)"
        }
      ]
    }
  },
  "scopeName": "source.sapphire"
}

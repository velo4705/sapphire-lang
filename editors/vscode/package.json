{
  "name": "sapphire-lang",
  "displayName": "Sapphire Language Support",
  "description": "Language support for Sapphire programming language",
  "version": "1.0.0",
  "publisher": "sapphire-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "sapphire",
    "programming language",
    "syntax highlighting"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sapphire",
        "aliases": [
          "Sapphire",
          "sapphire"
        ],
        "extensions": [
          ".spp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sapphire",
        "scopeName": "source.sapphire",
        "path": "./syntaxes/sapphire.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "sapphire"
      }
    ],
    "debuggers": [
      {
        "type": "sapphire",
        "label": "Sapphire Debug",
        "program": "./sapphire-debug",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to a Sapphire file.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "sapphire",
            "request": "launch",
            "name": "Debug Sapphire Program",
            "program": "${file}",
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Sapphire: Launch",
            "description": "A new configuration for debugging a Sapphire program",
            "body": {
              "type": "sapphire",
              "request": "launch",
              "name": "Debug Sapphire Program",
              "program": "^\"\\${file}\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Sapphire",
      "properties": {
        "sapphire.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Language Server Protocol support"
        },
        "sapphire.lsp.path": {
          "type": "string",
          "default": "sapphire-lsp",
          "description": "Path to sapphire-lsp executable"
        },
        "sapphire.debug.path": {
          "type": "string",
          "default": "sapphire-debug",
          "description": "Path to sapphire-debug executable"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}

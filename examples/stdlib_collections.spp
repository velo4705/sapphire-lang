# Note: These are conceptual examples showing how the collections
# module would be used once integrated with the interpreter

print("1. Set - Unique elements")
print("─────────────────────────────────────────────────────────")
# let s = Set()
# s.insert(1)
# s.insert(2)
# s.insert(1)  # Duplicate, won't be added
# print("Set size:", s.size())  # 2
# print("Contains 1:", s.contains(1))  # true
# print("Contains 3:", s.contains(3))  # false
print("  Set operations: insert, remove, contains")
print("  Unique elements only")
print("  O(log n) operations\n")

print("2. Queue - FIFO operations")
print("─────────────────────────────────────────────────────────")
# let q = Queue()
# q.enqueue(1)
# q.enqueue(2)
# q.enqueue(3)
# let first = q.dequeue()  # Some(1)
# let second = q.peek()    # Some(2)
print("  enqueue() - Add to back")
print("  dequeue() - Remove from front (returns Option)")
print("  peek() - View front without removing\n")

print("3. Stack - LIFO operations")
print("─────────────────────────────────────────────────────────")
# let stack = Stack()
# stack.push(1)
# stack.push(2)
# stack.push(3)
# let top = stack.pop()   # Some(3)
# let next = stack.peek() # Some(2)
print("  push() - Add to top")
print("  pop() - Remove from top (returns Option)")
print("  peek() - View top without removing\n")

print("4. Deque - Double-ended queue")
print("─────────────────────────────────────────────────────────")
# let dq = Deque()
# dq.push_front(1)
# dq.push_back(2)
# let front = dq.pop_front()  # Some(1)
# let back = dq.pop_back()    # Some(2)
print("  push_front() / push_back()")
print("  pop_front() / pop_back() (return Option)")
print("  Efficient operations at both ends\n")


# Trait with Impl Block

trait Printable:
    fn to_string(self) -> str

print("Trait defined")

class Point:
    fn __init__(self, x, y):
        self.x = x
        self.y = y

impl Printable for Point:
    fn to_string(self) -> str:
        return "Point"

print("Impl block registered")

let p = Point(3, 4)
print(p.to_string())
